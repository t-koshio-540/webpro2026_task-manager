datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// カテゴリーテーブル（1）
model Category {
  id    Int    @id @default(autoincrement())
  name  String
  tasks Task[] // 1つのカテゴリーは複数のタスクを持つ
}

// タスクテーブル（多）
model Task {
  id         Int      @id @default(autoincrement())
  title      String
  priority   Int      // 数値型の優先度（例: 1=低, 2=中, 3=高）
  is_deleted Boolean  @default(false) // 論理削除フラグ（デフォルトは削除されていない状態）
  
  // 外部キーとリレーションの定義
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}